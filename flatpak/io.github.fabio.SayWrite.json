{
  "app-id": "io.github.fabio.SayWrite",
  "runtime": "org.gnome.Platform",
  "runtime-version": "46",
  "sdk": "org.gnome.Sdk",
  "sdk-extensions": ["org.freedesktop.Sdk.Extension.rust-stable"],
  "command": "saywrite",
  "finish-args": [
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--socket=pulseaudio",
    "--device=dri",
    "--share=network",
    "--talk-name=org.freedesktop.portal.Desktop",
    "--talk-name=io.github.saywrite.Host"
  ],
  "build-options": {
    "append-path": "/usr/lib/sdk/rust-stable/bin"
  },
  "modules": [
    {
      "name": "whisper-cpp",
      "buildsystem": "cmake-ninja",
      "builddir": true,
      "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DWHISPER_BUILD_TESTS=OFF",
        "-DWHISPER_BUILD_EXAMPLES=ON",
        "-DGGML_NATIVE=OFF"
      ],
      "sources": [
        {
          "type": "dir",
          "path": "../vendor/whisper.cpp"
        }
      ],
      "post-install": [
        "install -Dm755 bin/whisper-cli /app/bin/whisper-cli"
      ]
    },
    {
      "name": "saywrite",
      "buildsystem": "simple",
      "build-commands": [
        "cargo --offline --locked build --release || cargo build --release",
        "install -Dm755 target/release/saywrite /app/bin/saywrite",
        "install -Dm644 data/io.github.fabio.SayWrite.desktop /app/share/applications/io.github.fabio.SayWrite.desktop",
        "install -Dm644 data/io.github.fabio.SayWrite.appdata.xml /app/share/metainfo/io.github.fabio.SayWrite.appdata.xml",
        "install -Dm644 data/io.github.fabio.SayWrite.svg /app/share/icons/hicolor/scalable/apps/io.github.fabio.SayWrite.svg"
      ],
      "sources": [
        {
          "type": "dir",
          "path": ".."
        }
      ]
    }
  ]
}
